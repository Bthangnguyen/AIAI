PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1

DB_POOL_MIN_SIZE=10
DB_POOL_MAX_SIZE=60
DB_POOL_TIMEOUT=10

RATE_LIMIT_PER_MINUTE=20

# Disable admin endpoints in production unless you intentionally expose them.
ADMIN_ENABLED=false
ADMIN_TOKEN=

# LLM provider. Fill exactly one usable provider key.
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=google/gemini-2.0-flash-001

# Optional Firebase Admin auth.
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=
GOOGLE_APPLICATION_CREDENTIALS=
