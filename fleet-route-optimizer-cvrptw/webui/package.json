{
  "name": "tripflow-ai-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:all": "vitest run && tsc --noEmit",
    "mock:gateway": "node scripts/mock-gateway.mjs",
