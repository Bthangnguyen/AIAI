PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1

# Postgres (matches docker-compose.yml defaults)
SQL_HOST=db
SQL_PORT=5432
SQL_DB=travel
SQL_USER=travel
SQL_PASSWORD=travel_secret

DB_POOL_MIN_SIZE=20
DB_POOL_MAX_SIZE=100
DB_POOL_TIMEOUT=10

# Layer 4 Solver (Docker Gateway → host Solver on Windows)
LAYER4_BASE_URL=http://host.docker.internal:8000

# LLM — fill ONE provider key before running live tests
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=google/gemini-2.0-flash-001

RATE_LIMIT_PER_MINUTE=5
